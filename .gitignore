# --- Wails ---
build/bin
frontend/wailsjs

# --- Frontend (Node/npm) ---
node_modules
frontend/node_modules/*
# main.go's //go:embed all:frontend/dist needs at least one file to resolve on
# a fresh checkout, before the frontend is ever built — keep the placeholder,
# ignore everything else the real build produces.
frontend/dist/*
!frontend/dist/.gitkeep
frontend/coverage/*
frontend/coverage/
frontend/tmp/*
frontend/*.js
frontend/*.d.ts
frontend/npm-debug.log*

# --- Go build artifacts ---
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Go workspaces
go.work
go.work.sum

# --- IDE & OS ---
.idea/
.vscode/*
.continue/*
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.DS_Store
Thumbs.db

# --- Sensitive data ---
*.env
*.env.local

# --- Project-specific ---
/qodana.yaml
.tmp/*
**/.tmp/*
.claude/settings.local.json
docs/superpowers/*

# Playwright MCP plugin output (AI debugging session artifacts)
.playwright-mcp/
# Root-level screenshots from debugging sessions
/*.png